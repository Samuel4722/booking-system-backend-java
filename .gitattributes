# Domyślne traktowanie plików jako tekst
* text=auto

# Skrypty
*.sh text eol=lf
*.cmd text eol=crlf
*.bat text eol=crlf
/mvnw text eol=lf

# Pliki tekstowe
*.java text
*.xml text
*.yaml text
*.yml text
*.properties text
*.md text
*.json text

# Pliki binarne
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
